// Установка зависимостей пакета (в т.ч. для разработки) в oscript_modules.
// Запуск: opm run install
#Использовать 1commands

Команда = Новый Команда;
Команда.УстановитьКоманду("opm");
Команда.ДобавитьПараметр("install");
Команда.ДобавитьПараметр("--dev");
Команда.ДобавитьПараметр("-l");
Команда.ПоказыватьВыводНемедленно(Истина);

КодВозврата = Команда.Исполнить();

Если КодВозврата <> 0 Тогда
	ВызватьИсключение "Установка зависимостей завершилась с кодом: " + КодВозврата;
КонецЕсли;

Сообщить("Зависимости установлены (opm install --dev -l).");
