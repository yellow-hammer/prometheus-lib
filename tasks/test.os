// Запуск тестов (1testrunner). Отчёт — out/tests.xml.
// Запуск: opm run test или opm test
#Использовать 1testrunner
#Использовать fs

ПутьКОтчетуJUnit = "out";
ФС.ОбеспечитьПустойКаталог(ПутьКОтчетуJUnit);

Тестер = Новый Тестер;
Тестер.УстановитьФорматЛогФайла(Тестер.ФорматыЛогФайла().GenericExec);

РезультатТестирования = Тестер.ТестироватьКаталог(
	Новый Файл("tests"),
	Новый Файл(ПутьКОтчетуJUnit)
);

Если РезультатТестирования = 0 Тогда
	ЗавершитьРаботу(0);
Иначе
	ЗавершитьРаботу(1);
КонецЕсли;
